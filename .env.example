BIODIETIX_ENV=development
BIODIETIX_AUTH_REQUIRED=false
BIODIETIX_APP_CHECK_REQUIRED=false
BIODIETIX_FIREBASE_CHECK_REVOKED=false
BIODIETIX_EXPOSE_DOCS=true
BIODIETIX_ALLOWED_ORIGINS=http://localhost:8501
BIODIETIX_ALLOWED_HOSTS=localhost,127.0.0.1
BIODIETIX_MAX_PDF_BYTES=10485760
BIODIETIX_MAX_JSON_BYTES=524288
BIODIETIX_WEB_PASSWORD=change-me-for-production
# Production only. Store the complete service-account JSON as a secret value.
BIODIETIX_FIREBASE_CREDENTIALS_JSON=
