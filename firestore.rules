rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function ownsUserData(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /environments/{environment}/users/{uid} {
      allow read, create, update, delete: if ownsUserData(uid);

      match /{document=**} {
        allow read, create, update, delete: if ownsUserData(uid);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
