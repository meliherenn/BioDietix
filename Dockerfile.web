FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    BIODIETIX_ENV=production

WORKDIR /app

RUN addgroup --system biodietix && adduser --system --ingroup biodietix biodietix

COPY requirements-api.txt requirements-web.txt ./
RUN pip install --upgrade pip && pip install -r requirements-web.txt

COPY app.py biodietix.py ./
COPY utils ./utils
COPY data ./data
COPY BioDietix_Recommendation_System.csv ./

USER biodietix

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=5s --start-period=45s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8501/_stcore/health', timeout=3)"

CMD ["sh", "-c", "streamlit run app.py --server.address=0.0.0.0 --server.port=${PORT:-8501} --server.headless=true"]
